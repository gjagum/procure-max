{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=procuremax.db"
  },
  "Auth": {
    "Issuer": "ProcureMax",
    "Audience": "ProcureMax",
    "SigningSecret": "DEV-ONLY-CHANGE-ME-32-char-minimum-secret-key-zzzz",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "SeedAdmin": {
    "Email": "admin@procuremax.local",
    "Password": "Admin#123",
    "Name": "System Administrator"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Procurement": {
    "MatchPriceTolerancePercent": 2,
    "MatchQtyTolerancePercent": 5
  }
}
