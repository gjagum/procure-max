{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=/data/procuremax.db"
  },
  "Auth": {
    "Issuer": "ProcureMax",
    "Audience": "ProcureMax",
    "SigningSecret": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "SeedAdmin": {
    "Email": "",
    "Password": "",
    "Name": "System Administrator"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Procurement": {
    "MatchPriceTolerancePercent": 2,
    "MatchQtyTolerancePercent": 5
  },
  "AllowedHosts": "*"
}
